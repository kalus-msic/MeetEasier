# Microsoft Graph / Azure AD app registration (recommended)
# Modern auth path — requires an app registration with Calendars.Read
# and Place.Read.All application permissions.
OAUTH_CLIENT_ID=
OAUTH_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
OAUTH_CLIENT_SECRET=

# Exchange Web Services (LEGACY — no longer maintained by Microsoft)
# Only used when SEARCH_USE_GRAPHAPI=false. Basic auth against EWS
# is deprecated in Microsoft 365; prefer Graph API above.
EWS_USERNAME=
EWS_PASSWORD=
EWS_URI=https://outlook.office365.com/EWS/Exchange.asmx

# Search settings (keep SEARCH_USE_GRAPHAPI=true unless you must use EWS)
SEARCH_USE_GRAPHAPI=true
SEARCH_MAXROOMLISTS=10
SEARCH_MAXDAYS=10
SEARCH_MAXITEMS=6

# Mail domain used for room mailboxes (e.g. CONTOSO.COM)
DOMAIN=

# Server
PORT=8080

# Frontend (React) configuration lives in ui-react/.env — see
# ui-react/.env.example. REACT_APP_* variables placed here have no
# effect because Create React App reads .env from its own directory.
