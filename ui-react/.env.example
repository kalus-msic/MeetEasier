# Frontend environment variables (Create React App)
#
# Copy this file to ui-react/.env and adjust values before running
# `npm run build` or `npm start`. REACT_APP_* variables are baked into
# the production bundle at build time.

# Show the room-list filter dropdown in the flightboard navbar
REACT_APP_ROOMLIST=true

# Show the Book / Extend / End meeting buttons on the single-room
# display. Enable only on touchscreen displays where booking makes
# sense. Requires Calendars.ReadWrite on the Azure AD app registration.
REACT_APP_BOOKING_ENABLED=false

# UI variant — "glass" (default, OLED dark Glass 2026 design) or
# "classic" (legacy flightboard + single-room layout, useful for e-ink
# or low-power displays where the glass aesthetic doesn't render well).
# Build-time switch: requires `npm run build` after changing.
REACT_APP_UI_VARIANT=glass

# Show the event organizer name (and initials avatar) on Glass dashboard
# and single-room views. Set to "false" if your room mailbox is configured
# to prepend the organizer to the event subject — typical for Exchange
# rooms with "AdditionalResponse" / "Add organizer to subject" enabled —
# so the organizer would otherwise appear twice. Defaults to "true".
REACT_APP_SHOW_ORGANIZER=true

# Booking modal — first/last hour displayed in the day timeline.
# Inclusive start, exclusive end. Defaults: 7 (07:00) and 21 (21:00).
REACT_APP_BOOKING_DAY_START=7
REACT_APP_BOOKING_DAY_END=21

# Maximum number of days into the future the user can book from the
# display. Should not exceed SEARCH_MAXDAYS in the backend .env (the
# socket only delivers events for SEARCH_MAXDAYS ahead, beyond which
# the timeline cannot show existing meetings). Default 10.
REACT_APP_BOOKING_MAX_DAYS_AHEAD=10

# Initial language of the on-screen Glass keyboard ("cs" or "en").
# Czech is QWERTZ with diacritics under long-press. Default "cs".
REACT_APP_KEYBOARD_DEFAULT=cs

# Subject written to the Outlook event when the user leaves the
# Subject field empty. Used as a fallback only.
REACT_APP_BOOKING_DEFAULT_SUBJECT=Rezervace z displeje
